    local oldKick
    oldKick = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        
        if method == "Kick" and self == LocalPlayer then
            warn("[Nova Bypass] Blocked kick attempt!")
            return
        end
        
        return oldKick(self, ...)
    end)
    
    -- Also protect against direct Kick function
    if hookfunction then
        local Players = game:GetService("Players")
        if LocalPlayer and LocalPlayer.Kick then
            hookfunction(LocalPlayer.Kick, function(...)
                warn("[Nova Bypass] Blocked direct kick!")
                return
            end)
        end
    end
    
    print("[Nova Bypass] Anti-kick protection loaded!")
end

