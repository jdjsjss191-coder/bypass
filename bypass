local function bypassAdonis()
    -- Find and disable Adonis client
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("LocalScript") and (v.Name:lower():find("adonis") or v.Name:lower():find("anti") or v.Name:lower():find("ac")) then
            pcall(function()
                v.Disabled = true
                v:Destroy()
            end)
        end
    end
    
    print("[Nova Bypass] Adonis bypass loaded!")
end

-- ============================================================================
-- REMOTE SPY PROTECTION
-- ============================================================================

local function protectRemotes()
    -- Prevent remote spy from detecting our modifications
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    
    -- Make our hooks invisible to remote spies
    if hookfunction and getrawmetatable then
        local oldGetMetatable = getrawmetatable
        
        hookfunction(getrawmetatable, newcclosure(function(obj)
            if not checkcaller() then
                -- Return a clean metatable to anti-cheats
                return {
                    __index = function() end,
                    __newindex = function() end,
                    __namecall = function() end
                }
            end
            return oldGetMetatable(obj)
        end))
    end
    
    setreadonly(mt, true)
    
    print("[Nova Bypass] Remote spy protection loaded!")
end

