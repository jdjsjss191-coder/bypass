local function protectHumanoid()
    -- Prevent detection of WalkSpeed/JumpPower changes
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    
    local oldNewIndex = mt.__newindex
    
    mt.__newindex = newcclosure(function(self, key, value)
        if not checkcaller() then
            -- Allow anti-cheat to see normal values
            return oldNewIndex(self, key, value)
        end
        
        -- Our script can modify freely
        if self:IsA("Humanoid") then
            if key == "WalkSpeed" or key == "JumpPower" or key == "JumpHeight" then
                -- Silently apply changes without triggering detection
                return oldNewIndex(self, key, value)
            end
        end
        
        return oldNewIndex(self, key, value)
    end)
    
    setreadonly(mt, true)
    
    print("[Nova Bypass] Humanoid protection loaded!")
end

