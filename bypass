-- Disable Adonis client-side detection
local function bypassAdonis()
    -- Find and disable Adonis client
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("LocalScript") and (v.Name:lower():find("adonis") or v.Name:lower():find("anti") or v.Name:lower():find("ac")) then
            pcall(function()
                v.Disabled = true
                v:Destroy()
            end)
        end
    end
    
    -- Hook Adonis remote detection
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    local oldIndex = mt.__index
    local oldNewIndex = mt.__newindex
    
    setreadonly(mt, false)
    
    -- Block Adonis kick/ban remotes
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if not checkcaller() then
            -- Block Adonis remotes
            if method == "FireServer" or method == "InvokeServer" then
                local remoteName = tostring(self)
                
                -- Block common Adonis remote names
                if remoteName:find("Detected") or 
                   remoteName:find("Security") or
                   remoteName:find("AntiCheat") or
                   remoteName:find("AC_") or
                   remoteName:find("KICK") or
                   remoteName:find("BAN") then
                    warn("[Nova Bypass] Blocked Adonis remote: " .. remoteName)
                    return
                end
                
                -- Block if first argument looks like a detection report
                if type(args[1]) == "string" then
                    local arg = args[1]:lower()
                    if arg:find("exploit") or 
                       arg:find("cheat") or 
                       arg:find("detected") or
                       arg:find("suspicious") or
                       arg:find("namecall") or
                       arg:find("metatable") then
                        warn("[Nova Bypass] Blocked detection report: " .. args[1])
                        return
                    end
                end
            end
        end
        
        return oldNamecall(self, ...)
    end)
    
    -- Protect against index detection
    mt.__index = newcclosure(function(self, key)
        if not checkcaller() then
            -- Spoof suspicious properties
            if key == "Parent" and typeof(self) == "Instance" then
                local result = oldIndex(self, key)
                -- Hide if parent is nil (destroyed objects)
                if result == nil and self.ClassName then
                    return workspace -- Spoof parent
                end
                return result
            end
        end
        return oldIndex(self, key)
    end)
    
    setreadonly(mt, true)
    
    print("[Nova Bypass] Adonis bypass loaded!")
end

-- ============================================================================
-- NAMECALL DETECTION BYPASS (For Silent Aim)
-- ============================================================================

local function bypassNamecallDetection()
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    
    local oldNamecall = mt.__namecall
    
    -- Store original namecall for our use
    local originalNamecall = oldNamecall
    
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        -- If it's our script calling (checkcaller returns true), use normal behavior
        if checkcaller() then
            return oldNamecall(self, ...)
        end
        
        -- Block anti-cheat checks for namecall method
        if method == "FireServer" or method == "InvokeServer" then
            -- Check if it's trying to report namecall usage
            if type(args[1]) == "string" then
                local arg = args[1]:lower()
                if arg:find("namecall") or 
                   arg:find("__namecall") or
                   arg:find("getnamecallmethod") or
                   arg:find("hookmetamethod") or
                   arg:find("hookfunction") then
                    warn("[Nova Bypass] Blocked namecall detection report")
                    return
                end
            end
            
            -- Check if it's trying to report Mouse.Hit spoofing
            if tostring(self):find("Mouse") or tostring(self):find("Tool") then
                if type(args[1]) == "table" or type(args[1]) == "CFrame" then
                    -- This might be legitimate gameplay, allow it
                    return oldNamecall(self, ...)
                end
            end
        end
        
        return oldNamecall(self, ...)
    end)
    
    setreadonly(mt, true)
    
    print("[Nova Bypass] Namecall detection bypass loaded!")
end

-- ============================================================================
-- REMOTE SPY PROTECTION
-- ============================================================================

local function protectRemotes()
    -- Prevent remote spy from detecting our modifications
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    
    -- Make our hooks invisible to remote spies
    local oldGetMetatable = getrawmetatable
    
    -- Hook getrawmetatable to return clean metatable to anti-cheats
    local function cleanMetatable(obj)
        local mt = oldGetMetatable(obj)
        if mt and not checkcaller() then
            -- Return a clean copy without our hooks
            local cleanMt = {}
            for k, v in pairs(mt) do
                if type(v) ~= "function" or k:sub(1, 2) ~= "__" then
                    cleanMt[k] = v
                end
            end
            return cleanMt
        end
        return mt
    end
    
    -- Protect against metatable detection
    if hookfunction then
        hookfunction(getrawmetatable, cleanMetatable)
    end
    
    setreadonly(mt, true)
    
    print("[Nova Bypass] Remote spy protection loaded!")
end

