local function spoofGetNamecallMethod()
    -- Make getnamecallmethod return false positives to anti-cheat
    if hookfunction and getnamecallmethod then
        local oldGetNamecallMethod = getnamecallmethod
        
        hookfunction(getnamecallmethod, newcclosure(function()
            -- If our script calls it, return real method
            if checkcaller() then
                return oldGetNamecallMethod()
            end
            
            -- If anti-cheat calls it, return a fake method
            -- This makes the anti-cheat think no hook exists
            return "FireServer" -- Return a safe default
        end))
        
        print("[Nova Bypass] getnamecallmethod spoofed!")
    end
end

-- ============================================================================
-- BLOCK NAMECALL INSTANCE DETECTOR
-- ============================================================================

local function blockNamecallInstanceDetector()
    -- This specifically blocks the "namecallinstance detector" kick
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    
    local oldNamecall = mt.__namecall
    
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if not checkcaller() then
            -- Block the specific namecallinstance detector
            if method == "FireServer" or method == "InvokeServer" then
                -- Check for namecallinstance detection
                if type(args[1]) == "string" and args[1]:lower():find("namecallinstance") then
                    warn("[Nova Bypass] Blocked namecallinstance detector!")
                    return
                end
                
                -- Check if remote name suggests it's a detector
                local remoteName = tostring(self)
                if remoteName:find("MainEvent") or 
                   remoteName:find("Detected") or
                   remoteName:find("CHECKER") or
                   remoteName:find("AC") then
                    
                    -- Scan all arguments for detection keywords
                    for _, arg in ipairs(args) do
                        if type(arg) == "string" then
                            local lower = arg:lower()
                            if lower:find("namecallinstance") or
                               lower:find("namecall") or
                               lower:find("instance") then
                                warn("[Nova Bypass] Blocked namecallinstance detector via: " .. remoteName)
                                return
                            end
                        elseif type(arg) == "table" then
                            -- Check table for detection data
                            for k, v in pairs(arg) do
                                if type(v) == "string" and v:lower():find("namecall") then
                                    warn("[Nova Bypass] Blocked namecallinstance detector (table arg)")
                                    return
                                end
                            end
                        end
                    end
                end
            end
        end
        
        return oldNamecall(self, ...)
    end)
    
    setreadonly(mt, true)
    
    print("[Nova Bypass] Namecallinstance detector blocked!")
end

-- ============================================================================
-- ADONIS ANTI-CHEAT BYPASS
