-- ADVANCED NAMECALL PROTECTION (Must run BEFORE any hooks)
-- ============================================================================

local function protectNamecallHook()
    -- Store original functions before any hooks
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    local oldIndex = mt.__index
    
    setreadonly(mt, false)
    
    -- Create a whitelist of allowed callers
    local allowedScripts = {}
    
    -- Hook __namecall to block detection
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        -- If our script is calling, allow it
        if checkcaller() then
            return oldNamecall(self, ...)
        end
        
        -- Block any remote that tries to detect namecall hooks
        if method == "FireServer" or method == "InvokeServer" then
            local remoteName = tostring(self):lower()
            
            -- Block detection remotes
            if remoteName:find("detect") or 
               remoteName:find("anticheat") or
               remoteName:find("ac") or
               remoteName:find("security") or
               remoteName:find("log") or
               remoteName:find("report") or
               remoteName:find("kick") or
               remoteName:find("ban") then
                
                -- Check if arguments contain detection keywords
                for i, arg in ipairs(args) do
                    if type(arg) == "string" then
                        local argLower = arg:lower()
                        if argLower:find("namecall") or
                           argLower:find("hook") or
                           argLower:find("metatable") or
                           argLower:find("exploit") or
                           argLower:find("cheat") or
                           argLower:find("__namecall") or
                           argLower:find("getnamecallmethod") then
                            warn("[Nova Bypass] Blocked detection remote: " .. remoteName .. " with arg: " .. arg)
                            return -- Block the remote call
                        end
                    end
                end
            end
        end
        
        return oldNamecall(self, ...)
    end)
    
    setreadonly(mt, true)
    
    print("[Nova Bypass] Namecall protection loaded!")
end

-- ============================================================================
-- SPOOF GETNAMECALLMETHOD
